# Supabase Configuration (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Standalone Server Port
PORT=8080

# Auto Sync Interval (dalam menit) — Rekomendasi: 10-15 menit
SYNC_INTERVAL_MINUTES=10

# Jam Operasional Worker (format: desimal jam, contoh 22.5 = 22:30)
# Di luar jam ini, worker akan skip sync otomatis
WORKING_HOUR_START=6
WORKING_HOUR_END=22.5

# IMAP Server Settings (Optional: bisa juga diisi di tabel app_settings Supabase)
IMAP_HOST=
IMAP_PORT=
IMAP_USER=
IMAP_PASS=
IMAP_SECURE=
