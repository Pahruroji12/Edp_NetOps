# Supabase Service Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-never-share-this

# Server Configuration
PORT=8080
SYNC_INTERVAL_MINUTES=10

# Operational Hour Sync (Format: Decimal, e.g. 6.0 = 06:00, 22.5 = 22:30)
WORKING_HOUR_START=6
WORKING_HOUR_END=22.5

# IMAP Configuration (Optional, can be overridden by table app_settings in Supabase)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=support@example.com
IMAP_PASS=your-email-app-password
IMAP_SECURE=true
